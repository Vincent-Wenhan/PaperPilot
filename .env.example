# PaperPilot environment variables.
# Copy to .env and adjust. All vars are optional; defaults are in config.py.

# --- LLM provider (OpenAI-compatible) ---
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# --- Optional per-stage model overrides (empty = use LLM_MODEL) ---
LLM_IMPLEMENTATION_MODEL=
LLM_CODE_REVIEW_MODEL=
LLM_RESEARCH_MODEL=

# --- Mock mode (no API key needed; returns deterministic mock outputs) ---
LLM_MOCK_MODE=false

# --- JSON mode toggle (some providers don't support response_format=json) ---
LLM_JSON_RESPONSE=true

# --- Max output tokens for structured agents (set to 0 to disable cap) ---
LLM_MAX_OUTPUT_TOKENS=8192
